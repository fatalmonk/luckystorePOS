{
  "buildCommand": "cd apps/admin_web && npm install && npm run build && mkdir -p ../../dist_public && cp -r dist/* ../../dist_public/",
  "outputDirectory": "dist_public",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Content-Type", "value": "application/javascript" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ]
}