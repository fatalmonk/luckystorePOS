{
  "buildCommand": "cd apps/customer_storefront && npm install --legacy-peer-deps && npx next build",
  "outputDirectory": "apps/customer_storefront/.next",
  "installCommand": "cd apps/customer_storefront && npm install --legacy-peer-deps",
  "framework": "nextjs",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {"key": "X-Content-Type-Options", "value": "nosniff"},
        {"key": "X-Frame-Options", "value": "DENY"},
        {"key": "X-XSS-Protection", "value": "1; mode=block"}
      ]
    }
  ]
}
