    { "source": "/admin/assets/(.*)", "destination": "/apps/admin_web/dist/assets/$1" },
    { "source": "/admin/sw.js", "destination": "/apps/admin_web/dist/sw.js" },
    { "source": "/admin/manifest.json", "destination": "/apps/admin_web/dist/manifest.json" },
    { "source": "/admin/pwa-192x192.png", "destination": "/apps/admin_web/dist/pwa-192x192.png" },
    { "source": "/admin/pwa-512x512.png", "destination": "/apps/admin_web/dist/pwa-512x512.png" },
