{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "allowJs": true,
    "noEmit": true
  },
  "include": ["scripts/**/*.js", "scripts/**/*.cjs", "scripts/**/*.mjs"],
  "exclude": ["node_modules"]
}
