{
  "name": "lucky-store",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Lucky Store monorepo — POS frontend, Supabase backend, scrapers, and ops scripts",
  "scripts": {
    "scrape": "node apps/scraper/scrape-shwapno.js",
    "import-competitor": "node scripts/ops/import-competitor-data.js",
    "remove-duplicates": "node scripts/ops/remove-duplicate-items.js",
    "remove-duplicates:dry-run": "node scripts/ops/remove-duplicate-items.js --dry-run",
    "scan:secrets": "node scripts/secret_scan.js",
    "facebook:post": "tsx src/facebook.ts",
    "typecheck": "tsc --noEmit"
  },
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3",
    "dotenv": "^17.2.2",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "workspaces": [
    "apps/*"
  ],
  "overrides": {
    "serialize-javascript": "^7.0.3",
    "terser": "^5.14.2",
    "uuid": "^11.1.1",
    "postcss": "^8.5.10",
    "tar-fs": "^3.1.1",
    "ws": "^8.17.1"
  }
}
