# ============================================================
# Lucky Store — Flutter Mobile App Environment Variables
# ============================================================
# ⚠️  SAFE-TO-BUNDLE: This file contains ONLY public/anon keys.
#     Never add SERVICE_ROLE_KEY, DB passwords, or admin credentials here.
#
# HOW TO USE:
#   cp env/.env.example env/.env.local
#   # Edit env/.env.local with real values — DO NOT commit env/.env.local
#
# ── Supabase (safe for browser / device) ─────────────────────────────────────
SUPABASE_URL="https://hvmyxyccfnkrbxqbhlnm.supabase.co"
SUPABASE_ANON_KEY="sb_publishable_fbM664Z8fllGMtvrmStZew_vMd-EcKX"

# ── Edge Functions ───────────────────────────────────────────────────────────
EDGE_FUNCTIONS_BASE_URL="https://hvmyxyccfnkrbxqbhlnm.supabase.co/functions/v1"

# ── Store Config ───────────────────────────────────────────────────────────────
# The real store ID for this deployment
DEFAULT_STORE_ID="4acf0fb2-f831-4205-b9f8-e1e8b4e6e8fd"

# ── Service Accounts (POS device authentication) ─────────────────────────────
# These are Supabase user credentials used by the POS app for authentication.
# NOT service role keys — these are regular user accounts with app_metadata.role.
MANAGER_EMAIL="manager@luckystore.com"
MANAGER_PASSWORD="your-manager-password"

ADMIN_EMAIL="admin@luckystore.com"
ADMIN_PASSWORD="your-admin-password"

CASHIER_EMAIL="cashier@luckystore.com"
CASHIER_PIN="2222"

# ── POS Device Config ─────────────────────────────────────────────────────────
DEVICE_ID="mobile-app-device-001"
DEVICE_NAME="Mobile Terminal"

# ── Integrations ─────────────────────────────────────────────────────────────
# SSLCommerz — safe for client-side. Production store token goes in server-side env.
SSLCOMMERZ_STORE_ID="your-store-id"
SSLCOMMERZ_STORE_PASSWORD="your-store-password"
SSLCOMMERZ_IS_LIVE="false"   # true for production, false for sandbox

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_OFFLINE_SYNC="true"
ENABLE_PRINT_RECEIPT="true"
RECEIPT_PRINTER_NAME="POS-80"
