{
  "framework": "vite",
  "buildCommand": "cd apps/admin_web && npm install && npm run build",
  "outputDirectory": "apps/admin_web/dist",
  "installCommand": "cd apps/admin_web && npm install",
  "env": {
    "VITE_SUPABASE_URL": "@vite_supabase_url",
    "VITE_SUPABASE_ANON_KEY": "@vite_supabase_anon_key"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}
