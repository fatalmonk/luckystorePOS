{
  "framework": "vite",
  "buildCommand": "cd apps/admin_web && npm install && npm run build",
  "outputDirectory": "apps/admin_web/dist",
  "installCommand": "cd apps/admin_web && npm install",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}
