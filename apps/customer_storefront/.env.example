# ============================================================
# Lucky Store — Customer Storefront Environment Variables
# ============================================================
# ⚠️  NEXT_PUBLIC_ prefix = exposed to browser (safe — anon/publishable keys only).
#     No server-side secrets here.
#
# HOW TO USE:
#   cp .env.example .env.local
#   # Edit .env.local with real values — DO NOT commit .env.local
#
# ── Supabase (safe for browser) ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://hvmyxyccfnkrbxqbhlnm.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key-here"

# ── Agent Worker (API gateway for database + images) ────────────────────────
# All database queries and image operations go through the agent Worker.
# The Worker handles auth — client just sends the Supabase JWT.
NEXT_PUBLIC_AGENT_WORKER_URL="https://agent.luckystore1947.com"

# ── Vercel (CI/CD — only needed if deploying to Vercel) ──────────────────────
# These are injected automatically by Vercel during CI/CD builds.
# DO NOT fill in manually — Vercel injects them at build time.
VERCEL_PROJECT_ID="prj_OXYSWyhB0307xKWe7BYSoZ2C1VIh"
# VERCEL_GIT_REPO_SLUG, VERCEL_GIT_COMMIT_SHA, etc. — injected by Vercel

# ── Feature Flags ───────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_REALTIME="true"
NEXT_PUBLIC_STORE_ID="4acf0fb2-f831-4205-b9f8-e1e8b4e6e8fd"
