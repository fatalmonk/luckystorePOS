# Lucky Store Monorepo — Root Environment Template
# Copy to `.env` and fill values. Keep `.env` out of git (already in .gitignore).

# ── Supabase Project Configuration ───────────────────────────────────────────
SUPABASE_URL="https://hvmyxyccfnkrbxqbhlnm.supabase.co"
SUPABASE_PROJECT_REF="hvmyxyccfnkrbxqbhlnm"

# ── Supabase Keys ────────────────────────────────────────────────────────────
# Anon key = public, safe for client-side code
SUPABASE_ANON_KEY="sb_publishable_fbM664Z8fllGMtvrmStZew_vMd-EcKX"

# Service role key = SECRET, server-side only, never expose to client
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imh2bXl4eWNjZm5rcmJ4cWJobG5tIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NDM3MTAyMywiZXhwIjoyMDg5OTQ3MDIzfQ.6upBdBJ2FZdh4pve6Q9cBdnVaT7Uigh_G_BfZkOZ96I"

# ── Database Connectivity (for migrations, scripts) ──────────────────────────
# Session pooler (Transaction mode) — for serverless/edge functions
DATABASE_URL="postgresql://postgres.hvmyxyccfnkrbxqbhlnm:***@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# Direct connection (Session mode) — for long-running connections, migrations
DIRECT_DATABASE_URL="postgresql://postgres:***@db.hvmyxyccfnkrbxqbhlnm.supabase.co:5432/postgres"
SUPABASE_DB_PASSWORD="mogme6-nizdub-ritnYz"

# ── Neon (Analytics Read Replica) ─────────────────────────────────────────────
# Neon Postgres — dedicated read database for admin dashboard analytics
# Schema synced from Supabase via scripts/sync-supabase-to-neon.mjs
# Admin web reads (reports, dashboard, competitor prices, daily sales) use this
VITE_NEON_DATABASE_URL="postgresql://neondb_owner:***@ep-damp-mud-aozaukim-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# ── Cloudflare (R2 Image Storage + Workers) ──────────────────────────────────
# Account ID
CLOUDFLARE_ACCOUNT_ID="8e457654e12c3b75d2094bbd8914030b"

# Wrangler API token (for deploying workers, managing R2)
CLOUDFLARE_API_TOKEN="your-cloudflare-api-token"

# R2 S3-compatible API credentials (for image uploads)
CLOUDFLARE_R2_ACCESS_KEY_ID="your-r2-access-key-id"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"

# R2 bucket config
R2_ACCOUNT_ID="8e457654e12c3b75d2094bbd8914030b"
R2_BUCKET_NAME="lucky-store-images"
R2_PUBLIC_URL="https://8e457654e12c3b75d2094bbd8914030b.r2.cloudflarestorage.com/lucky-store-images"

# Vite-exposed R2 config (for admin_web uploads)
VITE_R2_PUBLIC_URL="https://8e457654e12c3b75d2094bbd8914030b.r2.cloudflarestorage.com/lucky-store-images"
VITE_R2_ACCOUNT_ID="8e457654e12c3b75d2094bbd8914030b"
VITE_R2_ACCESS_KEY_ID="your-r2-access-key-id"
VITE_R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"

# Worker URL (after deployment)
CLOUDFLARE_IMAGE_WORKER_URL="https://lucky-store-images.your-subdomain.workers.dev"

# ── Supabase Management API ──────────────────────────────────────────────────
# For CI/CD, Mgmt API calls, running migrations via API
# Get from: Supabase Dashboard → Account → Access Tokens
SUPABASE_ACCESS_TOKEN="sbp_02ffe0a14a321dca3f3f21f8e0e0abefbc6f8c03"

# ── Production Store (Lucky Store) ───────────────────────────────────────────
# Only ONE real store in the database
PRODUCTION_STORE_ID="4acf0fb2-f831-4205-b9f8-e1e8b4e6e8fd"

# ── Ops & Notifications ───────────────────────────────────────────────────────
# Telegram bot for notifications (public token, safe)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ── SSLCommerz Payment Gateway ───────────────────────────────────────────────
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASSWORD=your_store_password
SSLCOMMERZ_IS_LIVE=false

# ── Google Services ──────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_key
GOOGLE_O_AUTH_CLIENT_ID=your_oauth_client_id

# ── AI / Scraping ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── Facebook Page Posting ────────────────────────────────────────────────────
# System user / page access token with pages_manage_posts permission
FACEBOOK_PAGE_ACCESS_TOKEN=your_page_access_token
FACEBOOK_PAGE_ID=your_facebook_page_id

# ── Vercel Deployment (optional) ─────────────────────────────────────────────
VERCEL_OIDC_TOKEN=only_needed_for_ci_cd
