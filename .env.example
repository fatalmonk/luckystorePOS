# Frontend (Vite)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_CREATE_SALE_EDGE_URL=https://your-project-ref.supabase.co/functions/v1/create-sale
VITE_PROCESS_SALE_EDGE_URL=https://your-project-ref.supabase.co/functions/v1/process-sale

# Node scripts
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Payment (SSLCommerz). Use API store_id and store_password from the merchant panel (not the display store name).
# Registered domain in the panel (e.g. https://ktlbd.com/) must match where callbacks are hosted.
# Sandbox session API (v4): https://sandbox.sslcommerz.com/gwprocess/v4/api.php — see https://developer.sslcommerz.com/doc/v4/
# validator https://sandbox.sslcommerz.com/validator/api/validationserverAPI.php (JSON validation, not ?wsdl)
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASSWORD=your_store_password
SSLCOMMERZ_IS_LIVE=false
# Optional override (e.g. legacy v3 only if SSLCOMMERZ still routes it): SSLCOMMERZ_SESSION_API_URL=...
# SSLCOMMERZ_VALIDATOR_URL=https://sandbox.sslcommerz.com/validator/api/validationserverAPI.php
SSLCOMMERZ_SUCCESS_URL=/api/sslcommerz/return/success
SSLCOMMERZ_FAIL_URL=/api/sslcommerz/return/fail
SSLCOMMERZ_CANCEL_URL=/api/sslcommerz/return/cancel
SSLCOMMERZ_IPN_URL=/api/sslcommerz/ipn
