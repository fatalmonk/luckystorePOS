# ============================================================
# Lucky Store — Root Environment Variables
# ============================================================
# ⚠️  SERVER-SIDE ONLY: Never expose these to browsers or clients.
#     Copy to .env.local and fill in real values.
#
# HOW TO USE:
#   cp .env.example .env.local
#   # Edit .env.local with real values — DO NOT commit .env.local
#
# ── Supabase (Project: hvmyxyccfnkrbxqbhlnm) ───────────────────────────────
# Project reference and public URL
SUPABASE_PROJECT_REF="hvmyxyccfnkrbxqbhlnm"
SUPABASE_URL="https://hvmyxyccfnkrbxqbhlnm.supabase.co"

# Service role key — SERVER SIDE ONLY. Used by: Node.js scripts, Supabase CLI,
# admin operations, migrations. NEVER put this in VITE_ or NEXT_PUBLIC_ vars.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# JWT secret — SERVER SIDE ONLY. Used for verifying JWTs locally (Supabase CLI).
# Found at: Supabase Dashboard → Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET="your-jwt-secret-here"

# Personal access token — Supabase Management API (supabase.management())
# Used by: CI/CD, migrations via Supabase CLI (not the same as service_role_key)
SUPABASE_ACCESS_TOKEN="sbp_..."

# Discovery URL — used by apps to fetch JWKS
SUPABASE_DISCOVERY_URL="https://hvmyxyccfnkrbxqbhlnm.supabase.co/auth/v1/.well-known/jwks.json"

# ── Supabase (Public/Anon Key — SAFE for client-side) ────────────────────────
# These CAN be in VITE_ / NEXT_PUBLIC_ vars (they are public by design).
# However, prefer reading from app-specific .env.local to keep concerns separated.
VITE_SUPABASE_URL="https://hvmyxyccfnkrbxqbhlnm.supabase.co"
VITE_SUPABASE_ANON_KEY="sb_publishable_fbM664Z8fllGMtvrmStZew_vMd-EcKX"

# ── Neon Read Replica (PostgreSQL via Cloudflare Workers) ───────────────────
# neon-proxy Worker: https://lucky-store-neon-proxy.luckystore-1947.workers.dev
# NEVER expose NEON_PROXY_API_KEY to browsers (it's a secret).
# Admin web and other server-side tools use this.
NEON_PROXY_URL="https://lucky-store-neon-proxy.luckystore-1947.workers.dev"
NEON_PROXY_API_KEY="your-neon-proxy-api-key-here"

# Client-facing Neon URL (used by browser for read-only queries via agent Worker)
VITE_NEON_PROXY_URL="https://lucky-store-neon-proxy.luckystore-1947.workers.dev"
# VITE_NEON_API_KEY is server-side only — put in app-specific .env.local, NOT here

# ── Database (Direct PostgreSQL — for local dev / migrations only) ───────────
# Find these at: Supabase Dashboard → Project Settings → Connection Pooling
# Use ONLY for local Supabase CLI or direct pg connections. NOT for app runtime.
DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-[REGION].pooler.supabase.com:5432/postgres"
DIRECT_DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres"
SUPABASE_DB_PASSWORD="your-db-password-here"

# ── Cloudflare ─────────────────────────────────────────────────────────────
# Used by: wrangler, scripts, Workers deployment
# Account ID found at: dash.cloudflare.com → overview page
CLOUDFLARE_ACCOUNT_ID="8e457654e12c3b75d2094bbd8914030b"
# API Token — created at dash.cloudflare.com → Profile → API Tokens
# Grant: Account Workers Scripts (edit), Zone Luckystore1947.com (edit)
CLOUDFLARE_API_TOKEN="your-cloudflare-api-token-here"

# ── Cloudflare Images / R2 ─────────────────────────────────────────────────
# R2 bucket for product images
R2_ACCOUNT_ID="your-r2-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret"
R2_BUCKET_NAME="lucky-store-images"
R2_PUBLIC_URL="https://images.luckystore1947.com"

# ── Payment: SSLCommerz ─────────────────────────────────────────────────────
# Production credentials — SERVER SIDE ONLY. Never expose to client.
SSLCOMMERZ_STORE_ID="your-store-id"
SSLCOMMERZ_STORE_PASSWORD="your-store-password"
SSLCOMMERZ_IS_LIVE=false   # true for production, false for sandbox

# ── OAuth / Agent Worker ────────────────────────────────────────────────────
# These are discovered at runtime from the agent Worker, not hardcoded.
# OAUTH_METADATA_URL=https://api.luckystore1947.com/.well-known/oauth-protected-resource
# AGENT_WORKER_URL=https://agent.luckystore1947.com

# ── WhatsApp Cloud API ─────────────────────────────────────────────────────
# Permanent system user access token — SERVER SIDE ONLY.
# Used by: checkout API to send order confirmations via WhatsApp Cloud API.
# Generate at: Meta Business Settings → System Users → Generate Token
WHATSAPP_ACCESS_TOKEN="your-whatsapp-access-token-here"

# WhatsApp Business phone number ID used as the 'from' number.
# Find in Meta App Dashboard → WhatsApp → API Setup.
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id-here"

# Optional: fallback click-to-chat number if Cloud API is unavailable.
WHATSAPP_FALLBACK_NUMBER="8801731944544"
